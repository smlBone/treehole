.workboddy/
文档.md
overview.md

# -------------------- 后端忽略（来自 backend/treehole/.gitignore） --------------------
# Maven 编译输出
**/target/
**/HELP.md
**/.mvn/wrapper/maven-wrapper.jar

# 但保留 src 下的 target（用于测试报告等）
!**/src/main/**/target/
!**/src/test/**/target/

# 后端配置文件（敏感）
**/src/main/resources/application.yaml
**/src/main/resources/application-local.yaml
**/src/main/resources/application-dev.yaml

# Eclipse / Spring Tool Suite
**/.apt_generated
**/.classpath
**/.factorypath
**/.project
**/.settings
**/.springBeans
**/.sts4-cache

# NetBeans
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbdist/
**/.nb-gradle/

# Gradle（如果使用）
**/build/
!**/src/main/**/build/
!**/src/test/**/build/

# -------------------- 前端忽略（来自 frontend/treehole/.gitignore） --------------------
# 日志文件
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# 依赖目录
**/node_modules/

# 构建输出
**/dist
**/dist-ssr

# 测试覆盖率
**/coverage
**/__screenshots__/
**/cypress/videos/
**/cypress/screenshots/

# 本地环境变量
**/*.local

# ESLint 缓存
**/.eslintcache
**/*.timestamp-*-*.mjs

# -------------------- 前后端共同的 IDE 配置 --------------------
# IntelliJ IDEA（前后端都有）
**/.idea/
**/*.iws
**/*.iml
**/*.ipr

# Visual Studio Code（统一忽略，但保留扩展推荐）
**/.vscode/*
!**/.vscode/extensions.json

# Visual Studio（Windows 开发）
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln

# 临时文件
**/*.sw?
**/*.tmp
**/*.temp

# -------------------- 操作系统生成文件 --------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------- 主仓库特定文件 --------------------
# 忽略主仓库根目录下的临时文件
*.log
*.tmp
temp/
tmp/

# 忽略环境变量文件（根目录）
.env
.env.local
.env.*.local

# 忽略 Docker 相关（如果有的话）
*.pid
docker-compose.override.yml

# 忽略备份文件
*.bak
*.backup
*~

# 忽略压缩包
*.zip
*.tar.gz
*.rar
*.7z